    {
      "parameters": {
        "jsCode": "const groups = {};\nfor (const item of $input.all()) {\n  const row = item.json;\n  const key = `${row['Employee ID']}_${row['Date']}`;\n  if (!groups[key]) {\n    groups[key] = { employeeId: row['Employee ID'], name: row['Name'], date: row['Date'], ins: [], outs: [] };\n  }\n  if (row['Punch Status'] === 'IN') groups[key].ins.push(row['Time']);\n  else groups[key].outs.push(row['Time']);\n}\nreturn Object.values(groups).map(g => {\n  const checkIn = g.ins.sort()[0] || null;\n  const checkOut = g.outs.sort().reverse()[0] || null;\n  return { json: { employeeId: g.employeeId, name: g.name, date: g.date, checkIn, checkOut, lateFlag: checkIn >= '11:00' ? 'YES' : 'NO' }};\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
